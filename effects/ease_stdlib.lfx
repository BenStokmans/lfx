version "0.1"
module "effects/ease_stdlib"
import "std/ease" as ease
effect "Ease Stdlib"
output scalar

function sample(width, height, x, y, index, phase, params)
  t = x / max(width, 1.0)
  return ease.smoothstep(clamp(t + phase - 0.5, 0.0, 1.0))
end

timeline {
  loop_start = 0.0
  loop_end = 1.0
}
