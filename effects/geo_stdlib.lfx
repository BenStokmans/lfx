version "0.1"
module "effects/geo_stdlib"
import "std/geo" as geo
effect "Geo Stdlib"
output scalar

function sample(width, height, x, y, index, phase, params)
  cx = (width - 1.0) / 2.0
  cy = (height - 1.0) / 2.0
  r = max(width, height) / 4.0
  d = geo.sdf_circle(x, y, cx, cy, r + phase * r * 0.5)
  return clamp(1.0 - abs(d) / max(r, 1.0), 0.0, 1.0)
end

timeline {
  loop_start = 0.0
  loop_end = 1.0
}
